@baseUrl = https://microbit-backend.velozz.workers.dev
@email = admin@velozz.com
@password = XDman100#
# Run Login once; authToken is pulled from that response for the rest of this file.
# API keys are letters-only and start with `velozz`.
# Seeded API key: `velozzadminseed`.
@authToken = {{login.response.body.$.sessionToken}}
@apiKey = {{createApiKey.response.body.$.item.apiKey}}
@commandId = {{createCommand.response.body.$.item.id}}

### Health
GET {{baseUrl}}/v1/health

### Login
# @name login
POST {{baseUrl}}/v1/auth/login
content-type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Me
GET {{baseUrl}}/v1/auth/me
Authorization: Bearer {{authToken}}

### List API Keys
GET {{baseUrl}}/v1/admin/api-keys
Authorization: Bearer {{authToken}}

### Create API Key
# @name createApiKey
POST {{baseUrl}}/v1/admin/api-keys
Authorization: Bearer {{authToken}}
content-type: application/json

{
  "label": "smoke-kit"
}

### API Key Detail
GET {{baseUrl}}/v1/admin/api-keys/{{apiKey}}
Authorization: Bearer {{authToken}}

### Create Command
# @name createCommand
POST {{baseUrl}}/v1/admin/api-keys/{{apiKey}}/command
Authorization: Bearer {{authToken}}
content-type: application/json

{
  "name": "show",
  "value": "7"
}

### List Commands
GET {{baseUrl}}/v1/admin/api-keys/{{apiKey}}/commands
Authorization: Bearer {{authToken}}

### App Snapshot
GET {{baseUrl}}/v1/app/devices/{{apiKey}}

### App Stream
GET {{baseUrl}}/v1/app/devices/{{apiKey}}/stream?deviceId={{apiKey}}
Accept: text/event-stream

### Microbit Ack
GET {{baseUrl}}/v1/microbit/ack?deviceId={{apiKey}}&cmdId={{commandId}}

### Microbit Pull
GET {{baseUrl}}/v1/microbit/pull?deviceId={{apiKey}}

### Microbit Send
GET {{baseUrl}}/v1/microbit/send?deviceId={{apiKey}}&name=light&value=88

### Microbit Heartbeat
GET {{baseUrl}}/v1/microbit/heartbeat?deviceId={{apiKey}}

### Logout
POST {{baseUrl}}/v1/auth/logout
Authorization: Bearer {{authToken}}
